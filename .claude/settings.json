{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys,json; d=json.load(sys.stdin); f=d.get('tool_input',{}).get('file_path') or d.get('tool_response',{}).get('filePath',''); print(f)\" | { read -r f; npx prettier --write \"$f\"; } 2>/dev/null || true",
            "statusMessage": "Prettierで整形中..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npx tailwindcss:*)",
      "Bash(npm run lint:*)",
      "Bash(npx tsc:*)",
      "Bash(git cherry-pick:*)",
      "Bash(cat:*)",
      "Bash(npm test:*)",
      "Bash(npx tsx:*)",
      "Bash(npm install:*)",
      "Bash(node -e:*)",
      "Bash(find:*)",
      "Bash(npm info:*)",
      "Bash(npx vitest:*)",
      "Bash(curl:*)",
      "Bash(git rm \"VIBES/*\")",
      "Bash(git mv \"VIBES/*\")",
      "WebSearch"
    ],
    "deny": []
  }
}
